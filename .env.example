# M31 Helpdesk FE — environment
# Base URL of the M31 API (mocked by MSW in dev/test)
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Toggle the whole Helpdesk UI/embed
NEXT_PUBLIC_HELPDESK_ENABLED=true

# Use MSW mock backend (true for the practice run; false against a real M31 API)
NEXT_PUBLIC_USE_MOCKS=true
