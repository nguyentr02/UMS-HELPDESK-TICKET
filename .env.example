# M31 Helpdesk FE — environment

# Base URL of the M31 API. When USE_MOCKS=true this is irrelevant
# (MSW intercepts in the browser). When false, set it to the real BE.
#
# Mock-mode default:   NEXT_PUBLIC_API_BASE_URL=/api/v1
# Real-BE (deployed):  NEXT_PUBLIC_API_BASE_URL=https://ums-helpdesk-api.vercel.app
# Real-BE (local dev): NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Toggle the whole Helpdesk UI/embed
NEXT_PUBLIC_HELPDESK_ENABLED=true

# Use MSW mock backend (true = MSW worker intercepts; false = real BE).
NEXT_PUBLIC_USE_MOCKS=true

# Socket.IO realtime server for the live notification bell. Optional — leave
# unset to disable (the bell falls back to its 30s poll). Base origin of the
# deployed realtime service. Prod: https://ums-helpdesk-realtime.onrender.com
NEXT_PUBLIC_REALTIME_URL=
